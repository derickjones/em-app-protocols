default_platform(:ios)

# One-time, human-only step (Account Holder access required — no Team API key
# role can do this, see docs/ios-app-workstream.md Phase 5 task 2):
#   appstoreconnect.apple.com -> Apps -> + -> New App
#   Bundle ID: app.emergencymedicine.ios (already registered via the API,
#   see scripts/register_asc_bundle_id.py)
# Every lane below operates on an *existing* app record and needs no further
# manual steps.

platform :ios do
  before_all do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false
    )
  end

  desc "Build, sign, and upload a build to TestFlight"
  lane :beta do
    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: latest_testflight_build_number(app_identifier: "app.emergencymedicine.ios") + 1
    )

    # xcodebuild's own -allowProvisioningUpdates couldn't resolve a team/
    # profile via the API key alone in this environment ("No Account for
    # Team..."), even with -authenticationKey* flags passed through. The
    # dedicated cert/sigh actions (below) use the same API key via
    # Spaceship::ConnectAPI and work reliably, so signing is done explicitly
    # here rather than left to xcodebuild to sort out at archive time.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: "Z4584RKFL3",
      code_sign_identity: "Apple Distribution",
      profile_name: "app.emergencymedicine.ios AppStore"
    )

    # The first time this creates a new "Apple Distribution" certificate,
    # macOS may show a Keychain "allow codesign to use this private key?"
    # dialog when gym later signs embedded frameworks. If running this in a
    # sandboxed/non-interactive shell where that dialog can't be answered,
    # run `fastlane beta` once from a normal interactive Terminal instead —
    # clicking "Always Allow" there fixes it permanently for future runs.
    get_certificates(development: false, team_id: "Z4584RKFL3")
    get_provisioning_profile(app_identifier: "app.emergencymedicine.ios", team_id: "Z4584RKFL3")

    # Neither sigh's own "Installing..." step nor the install_provisioning_
    # profile action actually places the profile where xcodebuild looks for
    # it in this environment (~/Library/MobileDevice/Provisioning Profiles/,
    # named <UUID>.mobileprovision) — do it explicitly.
    profiles_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    FileUtils.mkdir_p(profiles_dir)
    dest = File.join(profiles_dir, "#{lane_context[SharedValues::SIGH_UUID]}.mobileprovision")
    FileUtils.cp(lane_context[SharedValues::SIGH_PROFILE_PATH], dest)

    gym(
      project: "App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "app.emergencymedicine.ios" => "app.emergencymedicine.ios AppStore"
        }
      }
    )

    pilot(
      app_identifier: "app.emergencymedicine.ios",
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
